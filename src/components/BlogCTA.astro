---
interface Props {
	title?: string;
	description?: string;
	buttonText?: string;
	buttonLink?: string;
}

const {
	title = "Butuh bantuan merapikan customer service WhatsApp?",
	description = "Balesaja bisa membantu menyusun alur WhatsApp, bot, dan AI customer service yang sesuai dengan kebutuhan bisnis Anda.",
	buttonText = "Pelajari Balesaja",
	buttonLink = "https://s.id/pRI3k"

} = Astro.props;
---

<div class="blog-cta">
	<div class="cta-content">
		<h3>{title}</h3>
		<p>{description}</p>
		<a href={buttonLink} class="cta-button">{buttonText}</a>
	</div>
</div>

<style>
	.blog-cta {
		margin: 60px 0;
		padding: 48px;
		background: #0f172a;
		border-radius: 24px;
		color: #ffffff;
		text-align: center;
		position: relative;
		overflow: hidden;
	}

	.blog-cta::before {
		content: "";
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: radial-gradient(circle at 50% 50%, rgba(37, 99, 235, 0.2), transparent);
		pointer-events: none;
	}

	.cta-content {
		position: relative;
		z-index: 1;
	}

	.blog-cta h3 {
		color: #ffffff;
		font-size: 1.8rem;
		font-weight: 800;
		margin-bottom: 16px;
		line-height: 1.2;
	}

	.blog-cta p {
		color: rgba(255, 255, 255, 0.8);
		font-size: 1.1rem;
		margin-bottom: 32px;
		max-width: 500px;
		margin-left: auto;
		margin-right: auto;
	}

	.cta-button {
		display: inline-block;
		padding: 16px 32px;
		background: #2563eb;
		color: #ffffff;
		text-decoration: none;
		font-weight: 700;
		border-radius: 12px;
		transition: all 0.2s ease;
		box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.4);
	}

	.cta-button:hover {
		background: #1d4ed8;
		transform: translateY(-2px);
		box-shadow: 0 12px 30px -5px rgba(37, 99, 235, 0.5);
	}

	@media (max-width: 640px) {
		.blog-cta {
			padding: 32px 24px;
		}
		.blog-cta h3 {
			font-size: 1.5rem;
		}
	}
</style>
