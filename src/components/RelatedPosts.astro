---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	currentPostId: string;
	category?: string;
	tags?: string[];
}

const { currentPostId, category, tags = [] } = Astro.props;

const allPosts = await getCollection('blog');

// Find related posts based on category or tags
const relatedPosts = allPosts
	.filter((post) => {
		// Exclude the current post
		if (post.id === currentPostId) return false;

		// Match by category
		if (category && post.data.category === category) return true;

		// Match by tags (if any tag overlaps)
		if (tags.length > 0 && post.data.tags.some((tag) => tags.includes(tag))) {
			return true;
		}

		return false;
	})
	.slice(0, 3); // Show top 3 related posts
---

{relatedPosts.length > 0 && (
	<div class="related-posts">
		<h2 class="related-title">Artikel Terkait</h2>
		<div class="related-grid">
			{relatedPosts.map((post) => (
				<a href={`/blog/${post.id}/`} class="related-card">
					<div class="related-date">
						<FormattedDate date={post.data.pubDate} />
					</div>
					<h3>{post.data.title}</h3>
					<p>{post.data.description}</p>
				</a>
			))}
		</div>
	</div>
)}

<style>
	.related-posts {
		margin: 80px 0 40px;
		padding-top: 40px;
		border-top: 1px solid #f1f5f9;
	}
	.related-title {
		font-size: 1.5rem;
		font-weight: 800;
		color: #0f172a;
		margin-bottom: 32px;
	}
	.related-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 24px;
	}
	.related-card {
		text-decoration: none;
		display: block;
		padding: 24px;
		background: #f8fafc;
		border-radius: 16px;
		transition: all 0.2s ease;
		border: 1px solid transparent;
	}
	.related-card:hover {
		background: #ffffff;
		border-color: #2563eb;
		box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
		transform: translateY(-2px);
	}
	.related-date {
		font-size: 0.8rem;
		font-weight: 600;
		color: #94a3b8;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		margin-bottom: 12px;
	}
	.related-card h3 {
		font-size: 1.1rem;
		font-weight: 700;
		color: #0f172a;
		margin: 0 0 12px;
		line-height: 1.4;
	}
	.related-card p {
		font-size: 0.9rem;
		color: #64748b;
		line-height: 1.5;
		margin: 0;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
</style>
