---
import { SITE_LANG } from '../consts';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang={SITE_LANG}>
	<head>
		<BaseHead
			title="Balesaja.id | Jasa Setup Customer Service AI + Whitelabel"
			description="Otomatisasi layanan pelanggan Anda dengan AI CS tercanggih. Dukungan whitelabel untuk agensi dan bisnis."
		/>
		<style>
			:root {
				--page-bg: #ffffff;
				--panel: #f8fafc;
				--panel-strong: #f1f5f9;
				--line: rgba(0, 0, 0, 0.08);
				--muted: #64748b;
				--text: #0f172a;
				--primary: #2563eb;
				--primary-light: #60a5fa;
				--primary-dark: #1d4ed8;
				--ink: #ffffff;
				--accent: #3b82f6;
			}

			* {
				box-sizing: border-box;
			}

			body {
				min-height: 100vh;
				background: 
					radial-gradient(circle at 16% 6%, rgba(37, 99, 235, 0.05), transparent 31rem),
					radial-gradient(circle at 86% 16%, rgba(96, 165, 250, 0.05), transparent 28rem),
					var(--page-bg);
				color: var(--text);
				font-family:
					'Inter', ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
				font-size: 16px;
				line-height: 1.5;
				margin: 0;
			}

			a {
				color: inherit;
				transition: color 0.2s ease;
			}

			main {
				max-width: none;
				padding: 0;
				overflow: hidden;
			}

			.site-shell {
				width: min(1180px, calc(100% - 40px));
				margin: 0 auto;
			}

			.btn {
				display: inline-flex;
				align-items: center;
				justify-content: center;
				min-height: 46px;
				padding: 0 24px;
				border: 1px solid var(--line);
				border-radius: 10px;
				color: var(--text);
				font-size: 0.95rem;
				font-weight: 600;
				text-decoration: none;
				white-space: nowrap;
				transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
			}

			.btn-primary {
				background: var(--primary);
				color: var(--ink);
				border-color: transparent;
				box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.4);
			}

			.btn-primary:hover {
				background: var(--primary-dark);
				transform: translateY(-1px);
				box-shadow: 0 12px 30px -5px rgba(37, 99, 235, 0.5);
			}

			.btn-secondary {
				background: #ffffff;
			}

			.btn-secondary:hover {
				background: var(--panel);
				border-color: var(--primary-light);
			}

			.hero {
				position: relative;
				padding: 100px 0 80px;
			}

			.hero-grid {
				display: grid;
				grid-template-columns: 1.1fr 0.9fr;
				align-items: center;
				gap: 64px;
			}

			.badge {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				min-height: 32px;
				padding: 0 16px;
				border: 1px solid rgba(37, 99, 235, 0.15);
				border-radius: 999px;
				background: rgba(37, 99, 235, 0.08);
				color: var(--primary);
				font-size: 0.85rem;
				font-weight: 700;
				margin-bottom: 24px;
			}

			h1 {
				margin: 0 0 24px;
				color: var(--text);
				font-size: clamp(3rem, 6vw, 4.5rem);
				line-height: 1.1;
				letter-spacing: -0.03em;
				font-weight: 900;
			}

			h1 span {
				color: var(--primary);
				display: block;
			}

			.lede {
				max-width: 580px;
				margin: 0;
				color: var(--muted);
				font-size: clamp(1.1rem, 1.5vw, 1.25rem);
				line-height: 1.6;
			}

			.hero-actions {
				display: flex;
				align-items: center;
				flex-wrap: wrap;
				gap: 16px;
				margin: 40px 0 32px;
			}

			.trust-row {
				display: flex;
				flex-wrap: wrap;
				gap: 12px;
				color: var(--muted);
				font-size: 0.9rem;
				font-weight: 500;
			}

			.trust-pill {
				display: flex;
				align-items: center;
				gap: 6px;
				padding: 8px 16px;
				border: 1px solid var(--line);
				border-radius: 999px;
				background: #ffffff;
			}

			.trust-pill::before {
				content: "✓";
				color: var(--primary);
				font-weight: 900;
			}

			.product-preview {
				position: relative;
				padding: 12px;
				border: 1px solid var(--line);
				border-radius: 24px;
				background: #ffffff;
				box-shadow: 0 40px 80px -20px rgba(0, 0, 0, 0.1);
			}

			.product-window {
				overflow: hidden;
				border: 1px solid var(--line);
				border-radius: 16px;
				background: #ffffff;
			}

			.window-bar {
				display: flex;
				align-items: center;
				justify-content: space-between;
				padding: 12px 20px;
				border-bottom: 1px solid var(--line);
				background: var(--panel);
				color: var(--muted);
				font-size: 0.85rem;
				font-weight: 500;
			}

			.dots {
				display: flex;
				gap: 6px;
			}

			.dots span {
				width: 10px;
				height: 10px;
				border-radius: 50%;
				background: #cbd5e1;
			}

			.chat-interface {
				padding: 24px;
				background: #ffffff;
				min-height: 400px;
				display: flex;
				flex-direction: column;
				gap: 20px;
			}

			.chat-bubble {
				max-width: 80%;
				padding: 14px 18px;
				border-radius: 18px;
				font-size: 0.95rem;
				line-height: 1.5;
			}

			.bubble-ai {
				align-self: flex-start;
				background: var(--panel);
				color: var(--text);
				border-bottom-left-radius: 4px;
				border: 1px solid var(--line);
			}

			.bubble-user {
				align-self: flex-end;
				background: var(--primary);
				color: var(--ink);
				border-bottom-right-radius: 4px;
			}

			.whitelabel-tag {
				position: absolute;
				top: -20px;
				right: 30px;
				background: #0f172a;
				color: #ffffff;
				padding: 8px 20px;
				border-radius: 12px;
				font-size: 0.85rem;
				font-weight: 700;
				box-shadow: 0 10px 20px rgba(0,0,0,0.2);
			}

			.section {
				padding: 100px 0;
				border-top: 1px solid var(--line);
			}

			.section-header {
				text-align: center;
				max-width: 800px;
				margin: 0 auto 64px;
			}

			.kicker {
				display: block;
				color: var(--primary);
				font-weight: 800;
				font-size: 0.9rem;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				margin-bottom: 16px;
			}

			.section h2 {
				font-size: clamp(2.2rem, 4vw, 3.2rem);
				font-weight: 900;
				line-height: 1.1;
				margin: 0 0 20px;
				letter-spacing: -0.02em;
			}

			.feature-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 32px;
			}

			.feature-card {
				padding: 40px;
				border-radius: 20px;
				border: 1px solid var(--line);
				background: #ffffff;
				transition: all 0.3s ease;
			}

			.feature-card:hover {
				border-color: var(--primary-light);
				box-shadow: 0 20px 40px -10px rgba(37, 99, 235, 0.1);
				transform: translateY(-4px);
			}

			.icon-box {
				width: 54px;
				height: 54px;
				border-radius: 12px;
				background: rgba(37, 99, 235, 0.1);
				color: var(--primary);
				display: grid;
				place-items: center;
				font-size: 1.5rem;
				margin-bottom: 24px;
			}

			.feature-card h3 {
				font-size: 1.4rem;
				font-weight: 800;
				margin: 0 0 16px;
			}

			.feature-card p {
				color: var(--muted);
				font-size: 1rem;
				line-height: 1.6;
				margin: 0;
			}

			.workflow {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 24px;
			}

			.step {
				position: relative;
			}

			.step-num {
				font-size: 4rem;
				font-weight: 900;
				color: rgba(37, 99, 235, 0.08);
				line-height: 1;
				margin-bottom: -20px;
			}

			.step h3 {
				font-size: 1.25rem;
				font-weight: 800;
				margin: 0 0 12px;
				position: relative;
			}

			.step p {
				color: var(--muted);
				font-size: 0.95rem;
				margin: 0;
			}

			.cta-section {
				padding: 100px 0;
				background: var(--text);
				color: #ffffff;
				border-radius: 40px;
				margin: 0 20px 40px;
				text-align: center;
				position: relative;
				overflow: hidden;
			}

			.cta-section::before {
				content: "";
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background: radial-gradient(circle at 50% 50%, rgba(37, 99, 235, 0.2), transparent);
				pointer-events: none;
			}

			.cta-section h2 {
				font-size: clamp(2.5rem, 5vw, 4rem);
				font-weight: 900;
				margin-bottom: 24px;
			}

			@media (max-width: 980px) {
				.hero-grid {
					grid-template-columns: 1fr;
					text-align: center;
				}
				.lede {
					margin: 0 auto;
				}
				.hero-actions {
					justify-content: center;
				}
				.trust-row {
					justify-content: center;
				}
				.feature-grid {
					grid-template-columns: 1fr;
				}
				.workflow {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 640px) {
				.workflow {
					grid-template-columns: 1fr;
				}
				.cta-section {
					margin: 0 12px 24px;
					padding: 60px 20px;
				}
			}

			.testimonials-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 24px;
			}

			.testimonial-card {
				padding: 32px;
				border-radius: 20px;
				background: #ffffff;
				border: 1px solid var(--line);
				display: flex;
				flex-direction: column;
				gap: 20px;
			}

			.quote {
				font-size: 1.1rem;
				line-height: 1.6;
				color: var(--text);
				font-style: italic;
				margin: 0;
			}

			.author {
				display: flex;
				align-items: center;
				gap: 12px;
				margin-top: auto;
			}

			.author-info strong {
				display: block;
				font-size: 0.95rem;
				color: var(--text);
			}

			.author-info span {
				font-size: 0.85rem;
				color: var(--muted);
			}

			@media (max-width: 980px) {
				.testimonials-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>
	<body>
		<Header />

		<main>
			<section class="hero">
				<div class="site-shell hero-grid">
					<div>
						<span class="badge">AI Customer Service Specialist</span>
						<h1>Jasa Setup Customer Service <span>AI + Whitelabel</span></h1>
						<p class="lede">
							Tingkatkan efisiensi bisnis Anda dengan asisten AI yang cerdas. Bekerja 24/7 untuk menjawab pertanyaan pelanggan Anda dengan akurat.
						</p>
						<div class="hero-actions">
							<a class="btn btn-primary" href="https://s.id/pRI3k">Mulai Setup Sekarang</a>
							<a class="btn btn-secondary" href="#fitur">Lihat Fitur</a>
						</div>
						<div class="trust-row">
							<span class="trust-pill">Respon Cepat 24/7</span>
							<span class="trust-pill">Integrasi WhatsApp</span>
							<span class="trust-pill">Full Whitelabel</span>
						</div>
					</div>

					<div class="product-preview">
						<div class="whitelabel-tag">Your Brand Here</div>
						<div class="product-window">
							<div class="window-bar">
								<div class="dots"><span></span><span></span><span></span></div>
								<span>WhatsApp Business AI</span>
							</div>
							<div class="chat-interface">
								<div class="chat-bubble bubble-user">
									Halo, apakah produk ini ready stock?
								</div>
								<div class="chat-bubble bubble-ai">
									Halo! Iya, produk kami ready stock dan siap kirim hari ini. Ada lagi yang bisa saya bantu? 😊
								</div>
								<div class="chat-bubble bubble-user">
									Bisa kirim ke Jakarta pakai Instant?
								</div>
								<div class="chat-bubble bubble-ai">
									Tentu bisa! Untuk pengiriman ke Jakarta tersedia opsi kurir Instant (Gojek/Grab). Estimasi sampai dalam 2-3 jam setelah order diproses.
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="layanan" class="section">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Layanan Kami</span>
						<h2>Solusi WhatsApp & AI Terpercaya</h2>
					</div>
					<div class="feature-grid">
						<a href="/layanan/setup-whatsapp-business-ai/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">🤖</div>
							<h3>Setup AI CS</h3>
							<p>Otomatisasi layanan pelanggan 24/7 dengan asisten AI cerdas yang memahami konteks bisnis Anda.</p>
						</a>
						<a href="/layanan/bot-wa/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">⚡</div>
							<h3>Custom Bot WA</h3>
							<p>Pembuatan bot WhatsApp untuk cek resi, booking, pendaftaran, dan integrasi sistem kustom.</p>
						</a>
						<a href="/layanan/broadcast-whatsapp/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">📣</div>
							<h3>WA Blast Resmi</h3>
							<p>Kirim pesan massal (broadcast) secara resmi dan aman tanpa risiko blokir untuk promosi Anda.</p>
						</a>
						<a href="/layanan/whatsapp-business-api/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">🏢</div>
							<h3>WhatsApp API</h3>
							<p>Akses fitur Enterprise: multi-admin, centang hijau, dan integrasi CRM untuk skala besar.</p>
						</a>
						<a href="/layanan/white-label-ai-customer-service/" class="feature-card" style="text-decoration: none;">
							<div class="icon-box">🤝</div>
							<h3>White-Label</h3>
							<p>Peluang agensi untuk menjual kembali layanan AI CS kami dengan brand dan harga Anda sendiri.</p>
						</a>
						<a href="/blog" class="feature-card" style="text-decoration: none; border-style: dashed; background: var(--panel);">
							<div class="icon-box">📚</div>
							<h3>Wawasan & Blog</h3>
							<p>Pelajari strategi terbaru seputar WhatsApp marketing dan AI untuk pertumbuhan bisnis Anda.</p>
						</a>
					</div>
				</div>
			</section>

			<section id="fitur" class="section">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Fitur Unggulan</span>
						<h2>Solusi AI Lengkap untuk Bisnis Modern</h2>
					</div>
					<div class="feature-grid">
						<div class="feature-card">
							<div class="icon-box">💬</div>
							<h3>Smart Response</h3>
							<p>AI kami belajar dari data bisnis Anda untuk memberikan jawaban yang natural dan akurat layaknya manusia.</p>
						</div>
						<div class="feature-card">
							<div class="icon-box">🏷️</div>
							<h3>Full Whitelabel</h3>
							<p>Gunakan brand Anda sendiri. Hapus semua jejak Balesaja.id untuk menjaga eksklusivitas layanan Anda.</p>
						</div>
						<div class="feature-card">
							<div class="icon-box">📱</div>
							<h3>Multi-Platform</h3>
							<p>Satu AI untuk semua. Integrasikan dengan WhatsApp, Telegram, Website, dan Instagram Direct Message.</p>
						</div>
					</div>
				</div>
			</section>

			<section id="cara-kerja" class="section" style="background: var(--panel);">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Proses Kami</span>
						<h2>4 Langkah Menuju Otomatisasi</h2>
					</div>
					<div class="workflow">
						<div class="step">
							<div class="step-num">01</div>
							<h3>Konsultasi</h3>
							<p>Diskusi mendalam mengenai kebutuhan CS dan alur bisnis Anda.</p>
						</div>
						<div class="step">
							<div class="step-num">02</div>
							<h3>Knowledge Base</h3>
							<p>Kami melatih AI dengan data produk, FAQ, dan gaya bahasa brand Anda.</p>
						</div>
						<div class="step">
							<div class="step-num">03</div>
							<h3>Integrasi</h3>
							<p>Pemasangan sistem AI ke platform chat yang Anda gunakan.</p>
						</div>
						<div class="step">
							<div class="step-num">04</div>
							<h3>Go Live!</h3>
							<p>Sistem siap melayani pelanggan Anda secara otomatis 24/7.</p>
						</div>
					</div>
				</div>
			</section>

			<section id="testimonial" class="section" style="background: var(--panel);">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Testimoni</span>
						<h2>Apa Kata Mereka Tentang Balesaja.id</h2>
					</div>
					<div class="testimonials-grid">
						<div class="testimonial-card">
							<p class="quote">"Layanan luar biasa! AI-nya sangat cerdas dan membantu kami menangani 80% chat masuk secara otomatis tanpa kehilangan kualitas."</p>
							<div class="author">
								<div class="author-info">
									<strong>Andi Prasetya</strong>
									<span>Pemilik E-commerce</span>
								</div>
							</div>
						</div>
						<div class="testimonial-card">
							<p class="quote">"Whitelabel dashboard-nya sangat mudah digunakan. Klien agensi saya sangat puas dengan solusi AI yang kami tawarkan melalui Balesaja."</p>
							<div class="author">
								<div class="author-info">
									<strong>Budi Santoso</strong>
									<span>Founder Marketing Agency</span>
								</div>
							</div>
						</div>
						<div class="testimonial-card">
							<p class="quote">"Setup-nya sangat cepat dan tim support-nya sangat membantu dalam melatih AI kami. Bisnis jadi jauh lebih efisien sekarang!"</p>
							<div class="author">
								<div class="author-info">
									<strong>Citra Lestari</strong>
									<span>Startup Founder</span>
								</div>
							</div>
						</div>
					</div>
				</div>
			</section>

			<section id="whitelabel" class="section">
				<div class="site-shell">
					<div class="section-header">
						<span class="kicker">Peluang Agensi</span>
						<h2>Bangun Bisnis SaaS Anda Sendiri</h2>
						<p class="lede" style="margin: 0 auto;">Dengan fitur Whitelabel, Anda bisa menjual kembali layanan setup AI ini kepada klien Anda dengan harga dan brand Anda sendiri.</p>
					</div>
					<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center;">
						<div class="product-preview" style="background: var(--panel); display: flex; align-items: center; justify-content: center; min-height: 180px;">
							<img src="/logo.jpeg" alt="Your Logo Here" style="width: 120px; height: 120px; object-fit: contain; border-radius: 12px;" />
						</div>
						<div>
							<ul style="list-style: none; padding: 0; display: grid; gap: 20px;">
								<li style="display: flex; gap: 15px; font-size: 1.1rem;">
									<span style="color: var(--primary); font-weight: 900;">✓</span>
									Custom Domain & Dashboard
								</li>
								<li style="display: flex; gap: 15px; font-size: 1.1rem;">
									<span style="color: var(--primary); font-weight: 900;">✓</span>
									Laporan Performa untuk Klien
								</li>
								<li style="display: flex; gap: 15px; font-size: 1.1rem;">
									<span style="color: var(--primary); font-weight: 900;">✓</span>
									Kontrol Penuh Atas Harga Jual
								</li>
								<li style="display: flex; gap: 15px; font-size: 1.1rem;">
									<span style="color: var(--primary); font-weight: 900;">✓</span>
									Support Teknis dari Tim Kami
								</li>
							</ul>
						</div>
					</div>
				</div>
			</section>

			<div class="cta-section">
				<div class="site-shell">
					<h2>Siap Otomatisasi CS Anda?</h2>
					<p style="font-size: 1.2rem; margin-bottom: 40px; opacity: 0.9;">Bergabunglah dengan ratusan bisnis yang telah bertransformasi dengan AI.</p>
					<a class="btn btn-primary" href="https://s.id/pRI3k" style="background: #ffffff; color: var(--text); padding: 18px 40px; font-size: 1.1rem;">
						Hubungi Kami via WhatsApp
					</a>
				</div>
			</div>
