---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Pillar articles to highlight
const pillarSlugs = [
	'chatbot-whatsapp-untuk-bisnis',
	'jenis-jenis-ai-chatbot-untuk-bisnis',
	'alternatif-ai-chatbot-whatsapp-indonesia'
];

const pillarPosts = allPosts.filter(p => pillarSlugs.includes(p.id));
const otherPosts = allPosts.filter(p => !pillarSlugs.includes(p.id));

// Group by category
const categories = [...new Set(allPosts.map(p => p.data.category || 'Lainnya'))];
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1000px, 100% - 40px);
				margin: 0 auto;
				padding: 80px 0;
			}
			.blog-intro {
				text-align: center;
				max-width: 700px;
				margin: 0 auto 80px;
			}
			h1 {
				font-size: 3.5rem;
				font-weight: 900;
				margin-bottom: 24px;
				color: #0f172a;
			}
			.blog-intro p {
				font-size: 1.25rem;
				color: #64748b;
				line-height: 1.6;
			}
			
			.section-title {
				font-size: 1.5rem;
				font-weight: 800;
				margin: 60px 0 32px;
				padding-bottom: 12px;
				border-bottom: 2px solid #f1f5f9;
				color: #0f172a;
				display: flex;
				align-items: center;
				gap: 12px;
			}
			.section-title::before {
				content: "";
				width: 4px;
				height: 24px;
				background: #2563eb;
				border-radius: 2px;
			}

			.pillar-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 32px;
				margin-bottom: 80px;
			}
			.pillar-card {
				background: #ffffff;
				border: 1px solid #f1f5f9;
				border-radius: 20px;
				padding: 32px;
				text-decoration: none;
				transition: all 0.3s ease;
				display: flex;
				flex-direction: column;
				height: 100%;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
			}
			.pillar-card:hover {
				transform: translateY(-4px);
				border-color: #2563eb;
				box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
			}
			.pillar-card .pillar-label {
				font-size: 0.75rem;
				font-weight: 800;
				text-transform: uppercase;
				color: #2563eb;
				margin-bottom: 12px;
				letter-spacing: 0.05em;
			}
			.pillar-card h3 {
				font-size: 1.4rem;
				font-weight: 800;
				color: #0f172a;
				margin-bottom: 16px;
				line-height: 1.3;
			}
			.pillar-card p {
				color: #64748b;
				font-size: 1rem;
				line-height: 1.5;
				margin-bottom: 24px;
				flex-grow: 1;
			}
			.pillar-card .read-more {
				font-weight: 700;
				color: #2563eb;
				display: flex;
				align-items: center;
				gap: 8px;
			}

			.category-group {
				margin-bottom: 60px;
			}
			.post-list {
				display: grid;
				grid-template-columns: 1fr;
				gap: 24px;
				list-style: none;
				padding: 0;
			}
			.post-item a {
				text-decoration: none;
				display: grid;
				grid-template-columns: 140px 1fr;
				gap: 32px;
				align-items: start;
				padding: 24px;
				border-radius: 16px;
				transition: background 0.2s ease;
			}
			.post-item a:hover {
				background: #f8fafc;
			}
			.post-item .post-date {
				color: #94a3b8;
				font-size: 0.9rem;
				font-weight: 600;
			}
			.post-item .post-title {
				font-size: 1.25rem;
				font-weight: 700;
				color: #0f172a;
				margin-bottom: 8px;
				line-height: 1.3;
			}
			.post-item .post-description {
				color: #64748b;
				font-size: 1rem;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

			@media (max-width: 768px) {
				h1 { font-size: 2.5rem; }
				.post-item a {
					grid-template-columns: 1fr;
					gap: 8px;
					padding: 16px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-intro">
				<h1>Wawasan & Panduan</h1>
				<p>
					Temukan strategi terbaru seputar AI Customer Service, otomatisasi WhatsApp, 
					dan cara membangun alur komunikasi yang efektif untuk bisnis Anda.
				</p>
			</div>

			{pillarPosts.length > 0 && (
				<section>
					<h2 class="section-title">Panduan Utama</h2>
					<div class="pillar-grid">
						{pillarPosts.map(post => (
							<a href={`/blog/${post.id}/`} class="pillar-card">
								<span class="pillar-label">Pillar Article</span>
								<h3>{post.data.title}</h3>
								<p>{post.data.description}</p>
								<span class="read-more">Baca Selengkapnya →</span>
							</a>
						))}
					</div>
				</section>
			)}

			{categories.map(category => {
				const categoryPosts = otherPosts.filter(p => (p.data.category || 'Lainnya') === category);
				if (categoryPosts.length === 0) return null;
				
				return (
					<section class="category-group">
						<h2 class="section-title">{category}</h2>
						<ul class="post-list">
							{categoryPosts.map(post => (
								<li class="post-item">
									<a href={`/blog/${post.id}/`}>
										<div class="post-date">
											<FormattedDate date={post.data.pubDate} />
										</div>
										<div class="post-content">
											<h3 class="post-title">{post.data.title}</h3>
											<p class="post-description">{post.data.description}</p>
										</div>
									</a>
								</li>
							))}
						</ul>
					</section>
				);
			})}
		</main>
		<Footer />
	</body>
</html>
