---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Pillar articles to highlight
const pillarSlugs = [
	'chatbot-whatsapp-untuk-bisnis',
	'jenis-jenis-ai-chatbot-untuk-bisnis',
	'alternatif-ai-chatbot-whatsapp-indonesia'
];

const pillarPosts = allPosts.filter(p => pillarSlugs.includes(p.id));
const otherPosts = allPosts.filter(p => !pillarSlugs.includes(p.id));

// Prepare posts data for client-side search
const postsData = allPosts.map(p => ({
    id: p.id,
    title: p.data.title,
    description: p.data.description,
    category: p.data.category || 'Lainnya',
    pubDate: p.data.pubDate.toISOString()
}));
---

<!doctype html>
<html lang="id">
	<head>
		<BaseHead title={`Blog | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
		<style>
			main {
				width: min(1000px, 100% - 40px);
				margin: 0 auto;
				padding: 80px 0;
			}
			.blog-intro {
				text-align: center;
				max-width: 700px;
				margin: 0 auto 60px;
			}
			h1 {
				font-size: 3.5rem;
				font-weight: 900;
				margin-bottom: 24px;
				color: #0f172a;
			}
			.blog-intro p {
				font-size: 1.25rem;
				color: #64748b;
				line-height: 1.6;
			}

            /* Search Bar */
            .search-container {
                max-width: 600px;
                margin: 0 auto 80px;
                position: relative;
            }
            .search-input {
                width: 100%;
                padding: 16px 24px 16px 52px;
                border-radius: 16px;
                border: 2px solid #f1f5f9;
                background: #f8fafc;
                font-size: 1.1rem;
                transition: all 0.2s ease;
                outline: none;
            }
            .search-input:focus {
                border-color: #2563eb;
                background: #ffffff;
                box-shadow: 0 10px 25px -5px rgba(37, 99, 235, 0.1);
            }
            .search-icon {
                position: absolute;
                left: 20px;
                top: 50%;
                transform: translateY(-50%);
                color: #94a3b8;
                pointer-events: none;
            }
			
			.section-title {
				font-size: 1.5rem;
				font-weight: 800;
				margin: 60px 0 32px;
				padding-bottom: 12px;
				border-bottom: 2px solid #f1f5f9;
				color: #0f172a;
				display: flex;
				align-items: center;
				gap: 12px;
			}
			.section-title::before {
				content: "";
				width: 4px;
				height: 24px;
				background: #2563eb;
				border-radius: 2px;
			}

			.pillar-grid {
				display: grid;
				grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
				gap: 32px;
				margin-bottom: 80px;
			}
			.pillar-card {
				background: #ffffff;
				border: 1px solid #f1f5f9;
				border-radius: 20px;
				padding: 32px;
				text-decoration: none;
				transition: all 0.3s ease;
				display: flex;
				flex-direction: column;
				height: 100%;
				box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
			}
			.pillar-card:hover {
				transform: translateY(-4px);
				border-color: #2563eb;
				box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1);
			}
			.pillar-card h3 {
				font-size: 1.4rem;
				font-weight: 800;
				color: #0f172a;
				margin-bottom: 16px;
				line-height: 1.3;
			}
			.pillar-card p {
				color: #64748b;
				font-size: 1rem;
				line-height: 1.5;
				margin-bottom: 24px;
				flex-grow: 1;
			}
			.pillar-card .read-more {
				font-weight: 700;
				color: #2563eb;
				display: flex;
				align-items: center;
				gap: 8px;
			}

			.post-list {
				display: grid;
				grid-template-columns: 1fr;
				gap: 12px;
				list-style: none;
				padding: 0;
			}
			.post-item a {
				text-decoration: none;
				display: grid;
				grid-template-columns: 140px 1fr;
				gap: 32px;
				align-items: start;
				padding: 24px;
				border-radius: 16px;
				transition: background 0.2s ease;
			}
			.post-item a:hover {
				background: #f8fafc;
			}
			.post-item .post-date {
				color: #94a3b8;
				font-size: 0.9rem;
				font-weight: 600;
			}
			.post-item .post-title {
				font-size: 1.25rem;
				font-weight: 700;
				color: #0f172a;
				margin-bottom: 8px;
				line-height: 1.3;
			}
			.post-item .post-description {
				color: #64748b;
				font-size: 1rem;
				line-height: 1.5;
				display: -webkit-box;
				-webkit-line-clamp: 2;
				-webkit-box-orient: vertical;
				overflow: hidden;
			}

            /* Pagination */
            .load-more-container {
                display: flex;
                justify-content: center;
                margin: 60px 0 20px;
            }
            .load-more-btn {
                appearance: none;
                background: #ffffff;
                border: 2px solid #e2e8f0;
                border-radius: 14px;
                color: #0f172a;
                cursor: pointer;
                font-size: 1rem;
                font-weight: 700;
                padding: 16px 48px;
                transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            }
            .load-more-btn:hover {
                border-color: #2563eb;
                color: #2563eb;
                background: #f8fafc;
                transform: translateY(-2px);
                box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.1);
            }
            .load-more-btn:active {
                transform: translateY(0);
            }
            .load-more-btn:disabled {
                display: none;
            }

            /* Hidden state */
            .hidden { display: none !important; }

			@media (max-width: 768px) {
				h1 { font-size: 2.5rem; }
				.post-item a {
					grid-template-columns: 1fr;
					gap: 8px;
					padding: 16px;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<div class="blog-intro">
				<h1>Wawasan & Panduan</h1>
				<p>
					Temukan strategi terbaru seputar AI Customer Service, otomatisasi WhatsApp, 
					dan cara membangun alur komunikasi yang efektif.
				</p>
			</div>

            <div class="search-container">
                <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
                <input type="text" id="search-input" class="search-input" placeholder="Cari artikel..." autocomplete="off" />
            </div>

			<section id="pillars-section">
				<h2 class="section-title">Panduan Utama</h2>
				<div class="pillar-grid">
					{pillarPosts.map(post => (
						<a href={`/blog/${post.id}/`} class="pillar-card" data-title={post.data.title.toLowerCase()} data-desc={post.data.description.toLowerCase()}>
							<h3>{post.data.title}</h3>
							<p>{post.data.description}</p>
							<span class="read-more">Baca Selengkapnya →</span>
						</a>
					))}
				</div>
			</section>

            <section id="all-posts-section">
                <h2 class="section-title" id="posts-title">Semua Artikel</h2>
                <ul class="post-list" id="post-list">
                    {otherPosts.map((post, index) => (
                        <li class={`post-item ${index >= 6 ? 'hidden' : ''}`} data-index={index} data-title={post.data.title.toLowerCase()} data-desc={post.data.description.toLowerCase()}>
                            <a href={`/blog/${post.id}/`}>
                                <div class="post-date">
                                    <FormattedDate date={post.data.pubDate} />
                                </div>
                                <div class="post-content">
                                    <h3 class="post-title">{post.data.title}</h3>
                                    <p class="post-description">{post.data.description}</p>
                                </div>
                            </a>
                        </li>
                    ))}
                </ul>

                <div class="load-more-container" id="load-more-container">
                    <button id="load-more-btn" class="load-more-btn">Tampilkan Lebih Banyak</button>
                </div>
            </section>
		</main>
		<Footer />

        <script>
            const searchInput = document.getElementById('search-input') as HTMLInputElement;
            const postItems = document.querySelectorAll('.post-item');
            const pillarCards = document.querySelectorAll('.pillar-card');
            const pillarsSection = document.getElementById('pillars-section');
            const postsTitle = document.getElementById('posts-title');
            const loadMoreBtn = document.getElementById('load-more-btn') as HTMLButtonElement;
            
            let visibleCount = 6;
            const increment = 6;
            let isSearching = false;

            // Handle Search
            searchInput.addEventListener('input', (e) => {
                const query = (e.target as HTMLInputElement).value.toLowerCase().trim();
                isSearching = query.length > 0;

                if (isSearching) {
                    pillarsSection?.classList.add('hidden');
                    postsTitle!.textContent = 'Hasil Pencarian';
                    loadMoreBtn.classList.add('hidden');

                    postItems.forEach(item => {
                        const title = item.getAttribute('data-title') || '';
                        const desc = item.getAttribute('data-desc') || '';
                        if (title.includes(query) || desc.includes(query)) {
                            item.classList.remove('hidden');
                        } else {
                            item.classList.add('hidden');
                        }
                    });
                } else {
                    pillarsSection?.classList.remove('hidden');
                    postsTitle!.textContent = 'Semua Artikel';
                    loadMoreBtn.classList.remove('hidden');
                    resetPagination();
                }
            });

            // Handle Load More
            loadMoreBtn.addEventListener('click', () => {
                const hiddenItems = Array.from(postItems).filter(item => item.classList.contains('hidden'));
                const toShow = hiddenItems.slice(0, increment);
                
                toShow.forEach(item => item.classList.remove('hidden'));
                visibleCount += toShow.length;

                if (visibleCount >= postItems.length) {
                    loadMoreBtn.classList.add('hidden');
                }
            });

            function resetPagination() {
                visibleCount = 6;
                postItems.forEach((item, index) => {
                    if (index < visibleCount) {
                        item.classList.remove('hidden');
                    } else {
                        item.classList.add('hidden');
                    }
                });
                
                if (postItems.length <= visibleCount) {
                    loadMoreBtn.classList.add('hidden');
                } else {
                    loadMoreBtn.classList.remove('hidden');
                }
            }

            // Initial check
            if (postItems.length <= visibleCount) {
                loadMoreBtn.classList.add('hidden');
            }
        </script>
	</body>
</html>
