---
import type { MarkdownHeading } from 'astro';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import BlogCTA from '../components/BlogCTA.astro';
import RelatedPosts from '../components/RelatedPosts.astro';

type Props = CollectionEntry<'blog'> & {
	headings: MarkdownHeading[];
};

const { id, data, headings } = Astro.props;
const { 
	title, 
	description, 
	pubDate, 
	updatedDate, 
	heroImage,
	ctaTitle,
	ctaDescription,
	ctaLink,
	ctaButton,
	canonical,
	noindex,
	faq,
	category,
	tags
} = data;

// Generate FAQPage Schema
const faqSchema = faq ? {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": faq.map(f => ({
		"@type": "Question",
		"name": f.question,
		"acceptedAnswer": {
			"@type": "Answer",
			"text": f.answer
		}
	}))
} : null;

// Filter headings to show only depth 2 and 3 for the TOC
const toc = headings.filter((h) => h.depth > 1 && h.depth < 4);

// Generate dynamic OG image URL
// Since the file is /blog/[slug]/index.astro, the image is at ./og.png
const ogImage = `${Astro.url.pathname.replace(/\/$/, '')}/og.png`;

const articleSchema = {
	"@context": "https://schema.org",
	"@type": "Article",
	"headline": title,
	"description": description,
	"datePublished": pubDate.toISOString(),
	...(updatedDate && { "dateModified": updatedDate.toISOString() }),
	"author": {
		"@type": "Organization",
		"name": "Balesaja",
		"url": "https://balesaja.id"
	},
	"publisher": {
		"@type": "Organization",
		"name": "Balesaja",
		"url": "https://balesaja.id",
		"logo": {
			"@type": "ImageObject",
			"url": new URL('/logo.jpeg', Astro.site)
		}
	},
	"mainEntityOfPage": {
		"@type": "WebPage",
		"@id": new URL(Astro.url.pathname, Astro.site)
	}
};

const breadcrumbs = [
	{ name: 'Home', item: '/' },
	{ name: 'Blog', item: '/blog/' },
	{ name: title, item: Astro.url.pathname }
];
---

<html lang="id" style="scroll-behavior: smooth;">
	<head>
		<BaseHead title={title} description={description} image={ogImage} canonical={canonical} noindex={noindex} breadcrumbs={breadcrumbs} />


		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
		{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}

		<style>
			main {
				width: 100vw;
				margin-left: calc(-50vw + 50%);
				margin-right: calc(-50vw + 50%);
				padding: 80px 0;
			}
			.content-layout {
				display: grid;
				grid-template-columns: 1fr min(720px, calc(100% - 40px)) 1fr;
				width: 100%;
				align-items: start;
			}
			.prose {
				grid-column: 2;
				width: 100%;
				color: #334155;
				font-size: 1.15rem;
				line-height: 1.8;
			}
			.title {
				margin-bottom: 48px;
				text-align: center;
			}
			.title h1 {
				margin: 0 0 16px 0;
				font-size: clamp(2.5rem, 5vw, 3.5rem);
				font-weight: 900;
				color: #0f172a;
				line-height: 1.1;
			}
			.date {
				margin-bottom: 12px;
				color: #64748b;
				font-weight: 600;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				font-size: 0.9rem;
			}
			.last-updated-on {
				font-style: italic;
				font-size: 0.9rem;
				margin-top: 8px;
				color: #94a3b8;
			}
			
			/* TOC Sidebar Styles */
			.toc-sidebar {
				grid-column: 3;
				position: sticky;
				top: 120px;
				width: 280px;
				padding-left: 48px;
				height: fit-content;
			}
			.toc-title {
				font-size: 0.85rem;
				font-weight: 800;
				text-transform: uppercase;
				letter-spacing: 0.1em;
				color: #0f172a;
				margin-bottom: 20px;
				padding-bottom: 12px;
				border-bottom: 1px solid rgba(0,0,0,0.05);
			}
			.toc-list {
				list-style: none;
				padding: 0;
				margin: 0;
				display: flex;
				flex-direction: column;
				gap: 12px;
			}
			.toc-item a {
				text-decoration: none;
				color: #64748b;
				font-size: 0.9rem;
				line-height: 1.4;
				transition: color 0.2s ease;
				display: block;
			}
			.toc-item a:hover {
				color: #2563eb;
			}
			.prose :global(h2),
			.prose :global(h3) {
				scroll-margin-top: 180px;
			}

			.depth-3 {
				padding-left: 16px;
				font-size: 0.85rem;
			}

			@media (max-width: 1300px) {
				.toc-sidebar {
					width: 240px;
					padding-left: 32px;
				}
			}

			@media (max-width: 1100px) {
				.content-layout {
					grid-template-columns: 1fr 280px;
					max-width: 1000px;
					margin: 0 auto;
					padding: 0 40px;
				}
				.prose {
					grid-column: 1;
				}
				.toc-sidebar {
					grid-column: 2;
					padding-left: 0;
				}
				.title {
					text-align: left;
				}
			}

			@media (max-width: 960px) {
				.content-layout {
					grid-template-columns: 1fr;
					gap: 40px;
				}
				.toc-sidebar {
					display: none;
				}
				.title {
					text-align: center;
				}
				.prose {
					margin: 0 auto;
				}
			}
			@media (max-width: 720px) {
				main {
					padding: 40px 0;
				}
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="content-layout">
					<!-- Empty div to balance the left side for centering -->
					<div class="left-spacer" aria-hidden="true"></div>

					<div class="prose">
						<div class="title">
							<div class="date">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<div class="last-updated-on">
											Terakhir diperbarui pada <FormattedDate date={updatedDate} />
										</div>
									)
								}
							</div>
							<h1>{title}</h1>
						</div>
						<slot />
						<RelatedPosts currentPostId={id} category={category} tags={tags} />
						<BlogCTA 
							title={ctaTitle} 
							description={ctaDescription} 
							buttonLink={ctaLink} 
							buttonText={ctaButton} 
						/>
					</div>

					<aside class="toc-sidebar">
						<nav>
							<div class="toc-title">Daftar Isi</div>
							<ul class="toc-list">
								{toc.map((heading) => (
									<li class={`toc-item depth-${heading.depth}`}>
										<a href={`#${heading.slug}`}>{heading.text}</a>
									</li>
								))}
							</ul>
						</nav>
					</aside>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
