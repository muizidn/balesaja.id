{
	"compatibility_date": "2026-05-08",
	"compatibility_flags": [
		"global_fetch_strictly_public"
	],
	"name": "my-astro-app",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"env": {
		"production": {
			"routes": [
				{
					"pattern": "balesaja.id",
					"custom_domain": true
				}
			]
		}
	}
}