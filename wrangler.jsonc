{
	"compatibility_date": "2026-05-08",
	"compatibility_flags": [
		"global_fetch_strictly_public",
		"nodejs_compat"
	],
	"name": "balesaja-id",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"routes": [
		{
			"pattern": "balesaja.id",
			"custom_domain": true
		},
		{
			"pattern": "www.balesaja.id",
			"custom_domain": true
		}
	]
}